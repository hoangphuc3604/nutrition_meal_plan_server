# --- AI / LLM ---

# Google Gemini API key (used in llmService)
API_KEY_GENERATE=your_google_gemini_api_key
LLM_PROVIDER=gemini-api
LLM_MODEL=gemini-2.0-flash-exp

# --- Worker / Feature Flags ---

# Enable/disable background worker for processing queue jobs
ENABLE_WORKER=true

# Enable/disable Unsplash image processing queues (fridge/recipe images)
ENABLE_PROCESS_IMAGE=false

# --- Redis (must match nutrition_backend) ---

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Database (same as nutrition_backend) ---

DEV_DB_HOST=localhost
DEV_DB_USER=postgres
DEV_DB_PORT=5432
DEV_DB_PASSWORD=your_password
DEV_DB_NAME=nutritiondb

# --- Server ---

PORT=4000
NODE_ENV=dev

# --- External APIs ---

# Unsplash API key used for image searching
IMAGE_SEARCHING_KEY=your_unsplash_access_key

# Cloudinary for image storage
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# --- Cron / Fridge expiry ---

# Cron schedule for scanning fridge (default: 9 AM every day)
FRIDGE_SCAN_CRON=0 9 * * *

# Number of days before expiry to trigger warnings
FRIDGE_EXPIRY_DAYS_BEFORE=2

# Timezone used for the fridge scan cron job
FRIDGE_SCAN_TZ=Asia/Ho_Chi_Minh

# --- Host used when building public image URLs in workers ---

HOST=http://localhost:4000