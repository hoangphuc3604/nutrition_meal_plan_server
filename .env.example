# Server Configuration
NODE_ENV=dev
PORT=4000
ENABLE_WORKER=true
RENDER=false

# Database Configuration (Development)
DEV_DB_URL=
DEV_DB_HOST=localhost
DEV_DB_USER=postgres
DEV_DB_PORT=5432
DEV_DB_PASSWORD=
DEV_DB_NAME=nutritiondb

# Database Configuration (Production)
PROD_DB_URL=
PROD_DB_HOST=
PROD_DB_USER=
PROD_DB_PORT=5432
PROD_DB_PASSWORD=
PROD_DB_NAME=

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Cloudinary Configuration (Image Uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
ENABLE_PROCESS_IMAGE=true

# Unsplash API (Image Searching)
IMAGE_SEARCHING_KEY=

# LLM Configuration (AI)
# Providers: gemini-api, vertex-ai, azure-openai
LLM_PROVIDER=gemini-api
LLM_MODEL=gemini-2.0-flash
LLM_TEMPERATURE=0.5
LLM_MAX_TOKENS=8192
LLM_TIMEOUT_MS=300000
LLM_MAX_RETRIES=2
LLM_RETRY_BACKOFF_MS=1000

# Google Gemini API (if LLM_PROVIDER=gemini-api)
# API_KEY_GENERATE or GOOGLE_GEMINI_API_KEY
API_KEY_GENERATE=
GOOGLE_GEMINI_API_KEY=

# Vertex AI (if LLM_PROVIDER=vertex-ai)
VERTEX_AI_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=

# Azure OpenAI (if LLM_PROVIDER=azure-openai)
OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://models.github.ai/inference

# Cron Jobs Configuration
FRIDGE_SCAN_CRON="0 9 * * *"
FRIDGE_EXPIRY_DAYS_BEFORE=1
FRIDGE_SCAN_TZ=UTC

# Generation History Configuration
HISTORY_MAX_PLANS=10
HISTORY_MAX_ITEMS_PER_PLAN=5
HISTORY_MAX_RECENT_RECIPES=20
GENERATE_DAY_DELAY_MS=1000